{
  "name": "bff",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsoa spec-and-routes && ts-node-dev --inspect -- src/server.ts",
    "build": "pnpm exec prisma generate && tsoa spec-and-routes && tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "tsoa:spec-and-routes": "tsoa spec-and-routes",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"prisma/**/*.prisma\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\" \"prisma/**/*.prisma\"",
    "prisma:generate": "pnpm exec prisma generate",
    "prisma:migrate": "pnpm exec prisma migrate dev",
    "prisma:studio": "pnpm exec prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1018.0",
    "@aws-sdk/s3-request-presigner": "^3.1018.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.2.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tsoa/runtime": "^6.6.0",
    "bcrypt": "^6.0.0",
    "bs58": "^6.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "common": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "envalid": "^8.1.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "file-type": "^16.5.4",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "pdf-parse": "^1.1.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.2.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^7.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "8.11.11",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.56.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
