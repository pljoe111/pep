{
  "name": "bff",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --inspect -- src/server.ts",
    "build": "pnpm exec prisma generate && tsoa spec-and-routes && tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "tsoa:spec-and-routes": "tsoa spec-and-routes",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"prisma/**/*.prisma\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\" \"prisma/**/*.prisma\"",
    "prisma:generate": "pnpm exec prisma generate",
    "prisma:migrate": "pnpm exec prisma migrate dev",
    "prisma:studio": "pnpm exec prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^7.2.0",
    "@tsoa/runtime": "^6.6.0",
    "common": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "envalid": "^8.1.1",
    "express": "^4.18.2",
    "prisma": "^7.2.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^8.56.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "@vitest/coverage-v8": "^1.1.0"
  }
}
