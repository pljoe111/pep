NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp_dev?schema=public
CORS_ORIGIN=http://localhost:5173
ENABLE_SWAGGER=true

# Solana token mints
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDT_MINT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB

# PyUSD (Solana Token-2022)
# mainnet: 2b1kV6DkPAnxd5ixfnxCpjxmKwqjjaYmCZfHsFu24GXo
# devnet:  CXk2AMBfi3TwaEL2468s6zP8xq9NxTXjp9gjMgzeUynM
PYUSD_MINT=2b1kV6DkPAnxd5ixfnxCpjxmKwqjjaYmCZfHsFu24GXo

# Safety-net consolidation thresholds (residual balance, display units)
# Primary conversion happens instantly at deposit ingress — these are fallback only
CONSOLIDATION_THRESHOLD_USDC=100
CONSOLIDATION_THRESHOLD_PYUSD=100

# Email configuration
# Use 'nodemailer' for SMTP or 'resend' for API-based delivery
EMAIL_PROVIDER=nodemailer

# Nodemailer SMTP settings (used when EMAIL_PROVIDER=nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Resend API settings (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# Common email settings
EMAIL_FROM=noreply@peptest.com
OPERATOR_ALERT_EMAIL=ops@peptest.com

# Optionally override the seeded admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=yourStrongPasswordHere
