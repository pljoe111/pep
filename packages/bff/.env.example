NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp_dev?schema=public
CORS_ORIGIN=http://localhost:5173
ENABLE_SWAGGER=true

# Email configuration
# Use 'nodemailer' for SMTP or 'resend' for API-based delivery
EMAIL_PROVIDER=nodemailer

# Nodemailer SMTP settings (used when EMAIL_PROVIDER=nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Resend API settings (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# Common email settings
EMAIL_FROM=noreply@peptest.com
OPERATOR_ALERT_EMAIL=ops@peptest.com

# Optionally override the seeded admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=yourStrongPasswordHere
